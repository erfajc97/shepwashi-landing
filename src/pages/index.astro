---
import BaseLayout from "@/layouts/BaseLayout.astro";
import IntroVideo from "@/app/features/intro/components/IntroVideo";
import SmoothScroll from "@/app/shared/components/SmoothScroll";
import Navbar from "@/app/features/landing/components/Navbar";
import Hero from "@/app/features/landing/components/Hero";
import EventParallax from "@/app/features/event/components/EventParallax";
import CuatroEnfoques from "@/app/features/enfoques/components/CuatroEnfoques";
import CasoReferencia from "@/app/features/caso/components/CasoReferencia";
import ProcesoStack from "@/app/features/proceso/components/ProcesoStack";
import ProcesoClaro from "@/app/features/proceso-claro/components/ProcesoClaro";
import ServiciosPotenciar from "@/app/features/servicios/components/ServiciosPotenciar";
import AipRespaldo from "@/app/features/aip/components/AipRespaldo";
---

<BaseLayout title="Shepwashi — Plataformas seguras con IA">
  <SmoothScroll client:load />
  <IntroVideo client:load />
  <Navbar client:load />
  <main>
    <Hero client:load />
    <EventParallax client:load />
    <CuatroEnfoques client:load />
    <CasoReferencia client:load />
    <ProcesoStack client:load />
    <ProcesoClaro client:load />
    <ServiciosPotenciar client:load />
    <AipRespaldo client:load />
  </main>
</BaseLayout>
