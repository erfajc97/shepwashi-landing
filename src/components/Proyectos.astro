---
import { PROYECTOS } from "@/data/site";
---
<section id="proyectos" class="section-pad relative" style="background: var(--navy2);">
  <div class="max-w-6xl mx-auto">
    <div class="text-center flex flex-col items-center" style="margin-bottom: 52px;">
      <p class="eyebrow fade-up" style="margin-bottom: 18px;">{PROYECTOS.eyebrow}</p>
      <h2 class="h-section fade-up" data-d="1">{PROYECTOS.title}</h2>
      <p class="body-copy fade-up" data-d="2" style="max-width: 520px; margin-top: 18px;">
        {PROYECTOS.bajada}
      </p>
    </div>

    <div class="proy-grid">
      {PROYECTOS.items.map((p, i) => (
        <article class="proyecto-card fade-up" data-d={String(Math.min(3, i + 1))}>
          <span class="proy-vertical">{p.vertical}</span>
          <h3 class="proy-title">{p.title}</h3>

          <div class="proy-block">
            <span class="proy-k">Problema</span>
            <p class="proy-text">{p.problema}</p>
          </div>
          <div class="proy-block">
            <span class="proy-k">Solución</span>
            <p class="proy-text">{p.solucion}</p>
          </div>
          <div class="proy-block">
            <span class="proy-k">Impacto</span>
            <p class="proy-text" style="color: var(--gold2);">{p.impacto}</p>
          </div>

          <div class="proy-tech">
            {p.tech.map((t) => <span class="proy-chip">{t}</span>)}
          </div>
        </article>
      ))}
    </div>

    <div class="text-center fade-up" data-d="2" style="margin-top: 48px;">
      <a href="#contacto" class="btn-ghost">{PROYECTOS.cta}</a>
    </div>
  </div>
</section>

<style>
  .proy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 0.5px solid var(--border);
  }
  @media (max-width: 920px) { .proy-grid { grid-template-columns: 1fr; } }

  .proyecto-card {
    padding: 38px 32px;
    border-right: 0.5px solid var(--border);
    display: flex;
    flex-direction: column;
    transition: background 0.5s ease;
  }
  .proyecto-card:last-child { border-right: none; }
  .proyecto-card:hover { background: rgba(201, 168, 76, 0.045); }
  @media (max-width: 920px) {
    .proyecto-card {
      border-right: none;
      border-bottom: 0.5px solid var(--border);
    }
    .proyecto-card:last-child { border-bottom: none; }
  }

  .proy-vertical {
    font-family: var(--font-sans);
    font-size: 8.5px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
  }
  .proy-title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 26px;
    line-height: 1.15;
    color: var(--white);
    letter-spacing: -0.5px;
    margin: 14px 0 22px;
  }
  .proy-block { margin-bottom: 16px; }
  .proy-k {
    font-family: var(--font-sans);
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--hint);
    display: block;
    margin-bottom: 6px;
  }
  .proy-text {
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--muted);
    margin: 0;
  }
  .proy-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
    padding-top: 20px;
  }
  .proy-chip {
    font-family: var(--font-sans);
    font-size: 8px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
    border: 0.5px solid var(--border);
    padding: 5px 10px;
  }
</style>
