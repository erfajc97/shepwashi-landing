---
import { EQUIPO } from "@/data/site";
---
<section id="equipo" class="section-pad relative" style="background: var(--navy); border-top: 0.5px solid var(--border);">
  <div class="max-w-3xl mx-auto fade-up">
    <p class="eyebrow" style="margin-bottom: 22px;">{EQUIPO.eyebrow}</p>
    <h2 class="h-section" style="margin-bottom: 24px;">{EQUIPO.title}</h2>
    <p class="h-italic-gold" style="max-width: 56ch; color: var(--muted); font-style: normal; font-family: var(--font-display); font-size: clamp(19px, 2.4vw, 26px); line-height: 1.5;">
      {EQUIPO.lede}
    </p>
  </div>
</section>
