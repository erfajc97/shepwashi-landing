---
import { SUMMIT } from "@/data/site";
---
<section id="summit" class="summit-section relative overflow-hidden">
  <!-- Fondo: Four Seasons Cartagena -->
  <div class="summit-bg" aria-hidden="true">
    <img src={SUMMIT.bg} alt="" class="summit-bg-img" loading="lazy" decoding="async" />
    <div class="summit-bg-grad"></div>
  </div>

  <div class="section-pad relative" style="z-index: 2;">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">
        <div class="fade-up">
          <p class="eyebrow" style="margin-bottom: 18px;">{SUMMIT.eyebrow}</p>
          <h2 style="font-family: var(--font-display); font-weight: 300; font-size: clamp(44px, 6vw, 80px); line-height: 1; color: var(--white); letter-spacing: -1.5px;">
            {SUMMIT.title}
          </h2>

          <p class="h-italic-gold" style="margin-top: 14px;">{SUMMIT.fechas}</p>
          <p class="microcopy" style="margin-top: 8px; color: var(--muted);">{SUMMIT.sede}</p>

          <div class="divider-v" style="margin: 26px 0; height: 44px;"></div>
          <p class="body-copy" style="max-width: 420px;">{SUMMIT.copy}</p>

          <div style="margin-top: 32px;">
            <a href="#contacto" class="btn-primary">{SUMMIT.cta}</a>
            <p class="microcopy" style="margin-top: 16px; max-width: 360px;">{SUMMIT.note}</p>
          </div>
        </div>

        <div class="fade-up summit-ficha" data-d="2">
          {SUMMIT.ficha.map((f, i, arr) => (
            <div class="summit-row" style={i < arr.length - 1 ? "border-bottom: 0.5px solid var(--border);" : ""}>
              <span class="summit-k">{f.k}</span>
              <span class="summit-v">{f.v}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .summit-section { background: var(--navy); }

  .summit-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
  .summit-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.62) saturate(0.82) contrast(1.04);
  }
  .summit-bg-grad {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(5,14,26,0.62) 0%, rgba(5,14,26,0.48) 45%, rgba(5,14,26,0.84) 100%),
      radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.12), transparent 60%);
  }

  .summit-ficha {
    border: 0.5px solid var(--border);
    background: rgba(5, 14, 26, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .summit-row { padding: 20px 28px; display: flex; flex-direction: column; gap: 7px; transition: background 0.4s ease; }
  .summit-row:hover { background: rgba(201, 168, 76, 0.05); }
  .summit-k {
    font-family: var(--font-sans);
    font-size: 8.5px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
  }
  .summit-v {
    font-family: var(--font-sans);
    font-size: 12.5px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--white);
  }
</style>
