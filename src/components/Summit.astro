---
import { SUMMIT } from "@/data/site";
---
<section id="summit" class="summit-section relative overflow-hidden">
  <!-- Fondo: Four Seasons Cartagena -->
  <div class="summit-bg" aria-hidden="true">
    <img src={SUMMIT.bg} alt="" class="summit-bg-img" loading="lazy" decoding="async" />
    <div class="summit-bg-grad"></div>
  </div>

  <div class="section-pad relative" style="z-index: 2;">
    <div class="max-w-4xl mx-auto">
      <div class="fade-up">
        <p class="eyebrow" style="margin-bottom: 20px;">{SUMMIT.eyebrow}</p>
        <h2 class="summit-name">{SUMMIT.name}</h2>
        <p class="summit-phon">{SUMMIT.phon}</p>
        <p class="summit-tag">{SUMMIT.tagline}</p>
      </div>

      <div class="fade-up summit-details" data-d="2">
        {SUMMIT.details.map((f) => (
          <div class="summit-d">
            <span class="summit-k">{f.k}</span>
            <span class="summit-v">{f.v}</span>
          </div>
        ))}
      </div>

      <p class="summit-intro fade-up" data-d="2">{SUMMIT.intro}</p>

      <div class="fade-up" data-d="3" style="margin-top: 36px;">
        <a href={SUMMIT.ctaHref} class="btn-ghost" target="_blank" rel="noopener">{SUMMIT.cta}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .summit-section { background: var(--navy); }

  .summit-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden; pointer-events: none; }
  .summit-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.62) saturate(0.82) contrast(1.04);
  }
  .summit-bg-grad {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(5,14,26,0.62) 0%, rgba(5,14,26,0.48) 45%, rgba(5,14,26,0.84) 100%),
      radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.12), transparent 60%);
  }

  .summit-name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 7vw, 76px);
    color: var(--white);
    line-height: 1;
    letter-spacing: 0.5px;
  }
  .summit-phon {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--gold);
    font-size: 20px;
    letter-spacing: 2px;
    margin: 14px 0 0;
  }
  .summit-tag {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--muted);
    margin-top: 6px;
  }

  .summit-details {
    margin-top: 40px;
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    padding: 26px 0;
  }
  .summit-d { display: flex; flex-direction: column; gap: 6px; }
  .summit-k {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
  }
  .summit-v {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 300;
    color: var(--white);
  }
  .summit-intro {
    margin-top: 34px;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(18px, 2.2vw, 24px);
    line-height: 1.5;
    color: var(--muted);
    max-width: 54ch;
  }
</style>
