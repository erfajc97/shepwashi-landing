---
import { FOOTER } from "@/data/site";
const year = new Date().getFullYear();
const navCol = [
  { href: "#pilares",        label: "Quiénes somos" },
  { href: "#discernimiento", label: "Sobre la IA" },
  { href: "#proyectos",      label: "Proyectos" },
  { href: "#summit",         label: "Qarybe Summit" },
  { href: "#origen",         label: "Origen" },
  { href: "#contacto",       label: "Contacto" },
];
const ecosistema = [
  { href: "https://qaribe.netlify.app/", label: "Qarybe Summit", ext: true },
  { href: "#proyectos", label: "Luntriqa · Insurtech", ext: false },
];
---
<footer class="relative" style="background: var(--navy); border-top: 0.5px solid var(--border);">
  <div class="section-pad" style="padding-top: 64px; padding-bottom: 40px;">
    <div class="max-w-6xl mx-auto">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/images/logo.png" alt="Shepwashi" style="height: 30px; width: auto; margin-bottom: 8px;" />
          <p class="footer-phon">{FOOTER.phon}</p>
          <p class="body-copy" style="max-width: 320px; font-size: 12px; margin-top: 14px;">
            {FOOTER.tagline}
          </p>
        </div>

        <div class="footer-col">
          <span class="footer-head">Navegación</span>
          <ul>
            {navCol.map((l) => <li><a href={l.href} class="footer-link">{l.label}</a></li>)}
          </ul>
        </div>

        <div class="footer-col">
          <span class="footer-head">Ecosistema</span>
          <ul>
            {ecosistema.map((m) => (
              <li>
                {m.ext
                  ? <a href={m.href} class="footer-link" target="_blank" rel="noopener">{m.label}</a>
                  : <a href={m.href} class="footer-link">{m.label}</a>}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="divider-h" style="margin: 44px 0 24px;"></div>

      <div class="footer-bottom">
        <span class="microcopy">© {year} Shepwashi · Todos los derechos reservados</span>
        <span class="microcopy">{FOOTER.region}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; gap: 36px; }
  }

  .footer-phon {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--hint);
    margin: 0;
  }

  .footer-head {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 18px;
  }
  .footer-col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .footer-link {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 1.5px;
    color: var(--muted);
    transition: color 0.3s ease;
  }
  a.footer-link:hover { color: var(--gold); }
  .footer-static { cursor: default; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  @media (max-width: 600px) {
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
