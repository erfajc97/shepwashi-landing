---
const year = new Date().getFullYear();
const navCol = [
  { href: "#servicios", label: "Servicios" },
  { href: "#marcas",    label: "Marcas" },
  { href: "#summit",    label: "Qarybe Summit" },
  { href: "#proceso",   label: "Proceso" },
  { href: "#contacto",  label: "Contacto" },
];
const marcasCol = ["Luntriqa", "TodoDomi", "TodoServy"];
---
<footer class="relative" style="background: var(--navy); border-top: 0.5px solid var(--border);">
  <div class="section-pad" style="padding-top: 64px; padding-bottom: 40px;">
    <div class="max-w-6xl mx-auto">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/images/logo.png" alt="Shepwashi" style="height: 30px; width: auto; margin-bottom: 18px;" />
          <p class="body-copy" style="max-width: 320px; font-size: 12px;">
            Aliado tecnológico de largo plazo para empresas en LATAM.
            Consulting de IA, desarrollo a la medida e innovación.
          </p>
        </div>

        <div class="footer-col">
          <span class="footer-head">Navegación</span>
          <ul>
            {navCol.map((l) => <li><a href={l.href} class="footer-link">{l.label}</a></li>)}
          </ul>
        </div>

        <div class="footer-col">
          <span class="footer-head">Marcas propias</span>
          <ul>
            {marcasCol.map((m) => <li><span class="footer-link footer-static">{m}</span></li>)}
          </ul>
        </div>
      </div>

      <div class="divider-h" style="margin: 44px 0 24px;"></div>

      <div class="footer-bottom">
        <span class="microcopy">© {year} Shepwashi · Todos los derechos reservados</span>
        <span class="microcopy">Aliado tecnológico · LATAM</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 48px;
  }
  @media (max-width: 760px) {
    .footer-grid { grid-template-columns: 1fr; gap: 36px; }
  }

  .footer-head {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 18px;
  }
  .footer-col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .footer-link {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 1.5px;
    color: var(--muted);
    transition: color 0.3s ease;
  }
  a.footer-link:hover { color: var(--gold); }
  .footer-static { cursor: default; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  @media (max-width: 600px) {
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
