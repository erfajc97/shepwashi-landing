---
import { HERO } from "@/data/site";
---
<section id="top" class="hero-section relative overflow-hidden">
  <canvas id="sw-particles" aria-hidden="true"></canvas>

  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-aura" aria-hidden="true"></div>

  <div class="relative z-10 flex flex-col items-center text-center px-6 max-w-4xl mx-auto">
    <p class="hero-kicker fade-up" style="margin-bottom: 32px;">{HERO.kicker}</p>

    <h1 class="hero-headline" id="sw-headline">
      {HERO.lines.map((line, i) => (
        <span class="hw"><span class={`hw-in${i === HERO.lines.length - 1 ? " hw-accent" : ""}`} style={`transition-delay: ${i * 130}ms;`}>{line}</span></span>
      ))}
    </h1>

    <p class="hero-sub fade-up" data-d="2" style="margin-top: 30px;">
      {HERO.subhead}
    </p>

    <div class="hero-actions fade-up" data-d="3">
      <a href="#contacto" class="btn-primary">{HERO.cta}</a>
      <p class="hero-gloss"><span class="hero-gloss-word">{HERO.gloss.word}</span> — <em>{HERO.gloss.rest}</em></p>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: var(--navy);
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 104px 24px 72px;
  }
  @media (max-width: 768px) {
    .hero-section { padding: 96px 22px 60px; min-height: 100svh; }
  }

  #sw-particles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(201,168,76,0.12), transparent 58%),
      radial-gradient(ellipse at 50% 115%, rgba(5,14,26,0.7), transparent 60%);
  }
  /* breathing aura behind headline */
  .hero-aura {
    position: absolute;
    top: 38%;
    left: 50%;
    width: min(760px, 90vw);
    height: min(760px, 90vw);
    transform: translate(-50%, -50%);
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(circle, rgba(226,196,122,0.14), rgba(201,168,76,0.05) 40%, transparent 70%);
    animation: aura-breathe 7s ease-in-out infinite;
  }
  @keyframes aura-breathe {
    0%, 100% { opacity: 0.6; transform: translate(-50%, -50%) scale(0.92); }
    50%      { opacity: 1;   transform: translate(-50%, -50%) scale(1.08); }
  }

  /* ── Kicker ────────────────── */
  .hero-kicker {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ── Headline line reveal ────────────────── */
  .hero-headline {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(44px, 8.5vw, 108px);
    line-height: 0.98;
    letter-spacing: -0.5px;
    color: var(--white);
  }
  .hw {
    display: block;
    overflow: hidden;
    padding-bottom: 0.06em;
  }
  .hw-in {
    display: inline-block;
    transform: translateY(115%);
    opacity: 0;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.8s ease;
  }
  .hw-accent { color: var(--gold); font-style: italic; }
  .hero-headline.in .hw-in {
    transform: translateY(0);
    opacity: 1;
  }

  /* ── Sub ────────────────── */
  .hero-sub {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(18px, 2.3vw, 25px);
    line-height: 1.5;
    color: var(--muted);
    max-width: 50ch;
  }

  /* ── Actions + gloss ────────────────── */
  .hero-actions {
    margin-top: 46px;
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }
  .hero-gloss {
    margin: 0;
    max-width: 30ch;
    text-align: left;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 12.5px;
    line-height: 1.45;
    letter-spacing: 0.6px;
    color: var(--hint);
  }
  .hero-gloss-word { color: var(--gold); letter-spacing: 2px; text-transform: lowercase; }
  .hero-gloss em { font-style: italic; color: var(--muted); }
  @media (max-width: 560px) {
    .hero-actions { flex-direction: column; gap: 22px; }
    .hero-gloss { max-width: 38ch; text-align: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-aura { animation: none; }
    .hw-in { transition: none; transform: none; opacity: 1; }
  }
</style>

<script is:inline>
  (function () {
    // ── Headline word reveal (replays on scroll) ──
    const headline = document.getElementById("sw-headline");
    if (headline) {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce) {
        headline.classList.add("in");
      } else {
        const hio = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => headline.classList.toggle("in", e.isIntersecting));
          },
          { threshold: 0.25 }
        );
        hio.observe(headline);
      }
    }

    // ── Particles ──
    const canvas = document.getElementById("sw-particles");
    if (!canvas) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    let W = 0, H = 0, pts = [], dpr = Math.min(window.devicePixelRatio || 1, 2), raf = 0;

    function init() {
      const rect = canvas.parentElement.getBoundingClientRect();
      W = rect.width; H = rect.height;
      canvas.width = W * dpr; canvas.height = H * dpr;
      canvas.style.width = W + "px"; canvas.style.height = H + "px";
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(80, Math.floor((W * H) / 17000));
      pts = [];
      for (let i = 0; i < count; i++) {
        pts.push({
          x: Math.random() * W, y: Math.random() * H,
          r: Math.random() * 1.1 + 0.25,
          o: Math.random() * 0.32 + 0.06,
          speed: Math.random() * 0.11 + 0.03,
          dir: Math.random() > 0.5 ? 1 : -1,
        });
      }
    }
    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (const p of pts) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = "rgba(226, 196, 122, " + p.o.toFixed(3) + ")";
        ctx.fill();
        p.y -= p.speed;
        p.o += 0.0016 * p.dir;
        if (p.o > 0.42 || p.o < 0.05) p.dir *= -1;
        if (p.y < -4) { p.y = H + 4; p.x = Math.random() * W; }
      }
      raf = requestAnimationFrame(draw);
    }
    function start() { init(); cancelAnimationFrame(raf); draw(); }
    start();
    let to;
    window.addEventListener("resize", () => { clearTimeout(to); to = setTimeout(start, 150); });
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) cancelAnimationFrame(raf); else draw();
    });
  })();
</script>
