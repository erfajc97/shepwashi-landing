---
import { ORIGEN } from "@/data/site";
---
<section id="origen" class="origen-section section-pad relative">
  <div class="max-w-5xl mx-auto">
    <div class="origen-grid fade-up">
      <p class="eyebrow origen-eyebrow">{ORIGEN.eyebrow}</p>

      <div class="origen-word">
        {ORIGEN.word}<span class="origen-gloss">{ORIGEN.gloss}</span>
      </div>

      <p class="origen-intro">{ORIGEN.intro}</p>

      <p class="origen-close">{ORIGEN.close}</p>
    </div>
  </div>
</section>

<style>
  .origen-section {
    border-top: 0.5px solid var(--border);
    background: linear-gradient(180deg, var(--navy), var(--navy2));
  }
  .origen-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 40px 60px;
    align-items: center;
  }
  @media (max-width: 760px) { .origen-grid { grid-template-columns: 1fr; gap: 30px; } }

  .origen-eyebrow { grid-column: 1 / -1; }

  .origen-word {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(34px, 5vw, 58px);
    letter-spacing: 6px;
    color: var(--gold);
  }
  .origen-gloss {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 18px;
    letter-spacing: 1px;
    color: var(--muted);
    margin-top: 14px;
    text-transform: none;
  }
  .origen-intro {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(18px, 2.1vw, 23px);
    line-height: 1.55;
    color: var(--muted);
  }
  .origen-close {
    grid-column: 1 / -1;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(19px, 2.3vw, 25px);
    line-height: 1.5;
    color: var(--white);
    max-width: 60ch;
    border-top: 0.5px solid var(--border);
    padding-top: 34px;
    margin-top: 6px;
  }
</style>
