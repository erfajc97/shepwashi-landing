---
import { SERVICIOS } from "@/data/site";
---
<section id="servicios" class="section-pad relative" style="background: var(--navy2);">
  <div class="max-w-6xl mx-auto">
    <div class="text-center flex flex-col items-center" style="margin-bottom: 56px;">
      <p class="eyebrow fade-up" style="margin-bottom: 18px;">{SERVICIOS.eyebrow}</p>
      <h2 class="h-section fade-up" data-d="1">{SERVICIOS.title}</h2>
      <p class="body-copy fade-up" data-d="2" style="max-width: 520px; margin-top: 18px;">
        {SERVICIOS.bajada}
      </p>
    </div>

    <div class="svc-grid">
      {SERVICIOS.items.map((s, i) => (
        <article class="svc-card fade-up" data-d={String(Math.min(3, i + 1))}>
          <span class="deco-num">{s.n}</span>
          <span class="svc-accent" aria-hidden="true"></span>
          <h3 class="card-title" style="margin-bottom: 14px;">{s.title}</h3>
          <p class="card-body" style="margin-bottom: 22px;">{s.body}</p>
          <ul class="svc-points">
            {s.points.map((p) => (
              <li>
                <span class="svc-dot" aria-hidden="true"></span>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 0.5px solid var(--border);
  }
  @media (max-width: 920px) {
    .svc-grid { grid-template-columns: 1fr; }
  }

  .svc-card {
    padding: 44px 36px;
    border-right: 0.5px solid var(--border);
    transition: background 0.5s ease;
  }
  .svc-card:last-child { border-right: none; }
  .svc-card:hover { background: rgba(201, 168, 76, 0.045); }
  @media (max-width: 920px) {
    .svc-card {
      border-right: none;
      border-bottom: 0.5px solid var(--border);
      padding: 38px 28px;
    }
    .svc-card:last-child { border-bottom: none; }
  }

  .svc-accent {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--gold);
    margin: 18px 0 22px;
    transition: width 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .svc-card:hover .svc-accent { width: 56px; }

  .svc-points { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .svc-points li {
    display: flex;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--muted);
  }
  .svc-dot {
    flex: 0 0 auto;
    width: 4px; height: 4px;
    background: var(--gold);
    margin-top: 7px;
  }
</style>
