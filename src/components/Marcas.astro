---
import { MARCAS } from "@/data/site";
---
<section id="marcas" class="section-pad relative" style="background: var(--navy3);">
  <div class="max-w-6xl mx-auto">
    <div class="text-center flex flex-col items-center" style="margin-bottom: 52px;">
      <p class="eyebrow fade-up" style="margin-bottom: 18px;">{MARCAS.eyebrow}</p>
      <h2 class="h-section fade-up" data-d="1">{MARCAS.title}</h2>
      <p class="body-copy fade-up" data-d="2" style="max-width: 540px; margin-top: 18px;">
        {MARCAS.bajada}
      </p>
    </div>

    <div class="marcas-list">
      {MARCAS.items.map((m, i) => (
        <article class="marca-card fade-up" data-d={String(Math.min(3, i + 1))} style={`--acc: ${m.accent};`}>
          <span class="marca-topline" aria-hidden="true"></span>
          <div class="marca-grid">
            <div class="marca-id">
              <p class="marca-tag">{m.tag}</p>
              <h3 class="marca-name">{m.name}</h3>
            </div>
            <div class="marca-content">
              <p class="body-copy" style="margin-bottom: 22px;">{m.body}</p>
              <ul class="marca-points">
                {m.points.map((p) => (
                  <li>
                    <span class="marca-dot" aria-hidden="true"></span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .marcas-list { display: flex; flex-direction: column; gap: 1px; background: var(--border); border: 0.5px solid var(--border); }

  .marca-card {
    background: var(--navy3);
    padding: 0;
    position: relative;
    transition: background 0.5s ease;
  }
  .marca-card:hover { background: rgba(201, 168, 76, 0.035); }

  .marca-topline {
    display: block;
    height: 2px;
    width: 0;
    background: var(--acc);
    transition: width 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  .marca-card:hover .marca-topline { width: 100%; }

  .marca-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.6fr;
    gap: 40px;
    padding: 46px 44px;
  }
  @media (max-width: 880px) {
    .marca-grid { grid-template-columns: 1fr; gap: 22px; padding: 36px 26px; }
  }

  .marca-tag {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--acc);
    margin: 0 0 12px 0;
  }
  .marca-name {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1;
    color: var(--white);
    letter-spacing: -1px;
    margin: 0;
  }

  .marca-content { display: flex; flex-direction: column; }
  .marca-points { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 12px 28px; }
  @media (max-width: 560px) { .marca-points { grid-template-columns: 1fr; } }
  .marca-points li {
    display: flex;
    gap: 11px;
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 300;
    line-height: 1.65;
    color: var(--muted);
  }
  .marca-dot {
    flex: 0 0 auto;
    width: 4px; height: 4px;
    background: var(--acc);
    margin-top: 6px;
  }
</style>
